dn: olcDatabase={1}mdb,cn=config
changetype: modify
add: olcSyncrepl
olcSyncrepl: {0}rid=001
  provider=ldaps://ldap1.fis.epn.ec:636
  type=refreshAndPersist
  retry="5 5 300 5"
  searchbase="dc=fis,dc=epn,dc=ec"
  attrs="*,+"
  bindmethod=simple
  binddn="cn=admin,dc=fis,dc=epn,dc=ec"
  credentials=adminpas
  tls_reqcert=allow
